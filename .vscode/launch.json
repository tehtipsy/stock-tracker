{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev server (npm run dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "BROWSER": "none"
      }
    },
    {
      "name": "Attach to Chrome (localhost:5173)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "urlFilter": "http://localhost:5173/*",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Launch Chrome + Dev server",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "npm: dev",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full-stack debug",
      "configurations": ["Dev server (npm run dev)", "Attach to Chrome (localhost:5173)"]
    }
  ]
}
