{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev server (npm run dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "BROWSER": "none"
      },
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Launch Chrome (localhost:5173)",
        "pattern": "Local.*http://localhost",
        "killOnServerStop": true
      }
    },
    {
      "name": "Attach to Chrome (localhost:5173)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "urlFilter": "http://localhost:5173/*",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "/@fs/*": "/*",
        "/src/*": "${workspaceFolder}/src/*"
      }
    },
    {
      "name": "Launch Chrome (localhost:5173)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "/@fs/*": "/*",
        "/src/*": "${workspaceFolder}/src/*"
      }
    },
    {
      "name": "Vercel dev server (npm run dev:vercel)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev:vercel"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "autoAttachChildProcesses": true,
      "env": {
        "BROWSER": "none"
      },
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Launch Chrome (localhost:3000)",
        "pattern": "Available at http://localhost:\\d+"
      }
    },
    {
      "name": "Attach to Chrome (localhost:3000)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "urlFilter": "http://localhost:3000/*",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "http://localhost:3000/*": "${workspaceFolder}/*",
        "/@fs/*": "/*",
        "/src/*": "${workspaceFolder}/src/*"
      }
    },
    {
      "name": "Launch Chrome (localhost:3000)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "http://localhost:3000/*": "${workspaceFolder}/*",
        "/@fs/*": "/*",
        "/src/*": "${workspaceFolder}/src/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full-stack debug",
      "configurations": ["Dev server (npm run dev)"]
    },
    {
      "name": "Full-stack debug (Vercel)",
      "configurations": [
        "Vercel dev server (npm run dev:vercel)",
        "Attach to Chrome (localhost:3000)"
      ]
    },
    {
      "name": "Full-stack debug (Vercel, launch Chrome)",
      "configurations": [
        "Vercel dev server (npm run dev:vercel)"
      ]
    }
  ]
}
